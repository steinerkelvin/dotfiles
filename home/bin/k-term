#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# ///
"""
k-term - Launch an interactive terminal and capture its output

Spawns a terminal window with a command (or interactive shell) for the user
to interact with. Captures output via script(1) and replays it after the
session closes. Designed for AI assistants (Claude Code) to delegate
interactive tasks to the human.

Usage:
  k-term [options] [command] [args]    # Launch specific command
  k-term [options]                     # Launch interactive shell

Options:
  --json            Output structured JSON instead of plain text
  --title TEXT      Custom terminal window title
  --no-strip-ansi   Keep raw ANSI escape codes in output

Examples:
  k-term                               # Interactive shell
  k-term htop                          # Run htop
  k-term ssh user@host                 # SSH session
  k-term --json gcloud auth login      # JSON output for parsing
"""

import argparse
import atexit
import glob
import json
import os
import re
import shlex
import shutil
import signal
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Callable


# --- ANSI escape code stripping ---

# Matches ANSI escape sequences: CSI, OSC, and other ESC sequences
ANSI_RE = re.compile(
    r"\x1b"
    r"(?:"
    r"\[[\x30-\x3f]*[\x20-\x2f]*[\x40-\x7e]"  # CSI sequences
    r"|\].*?(?:\x1b\\|\x07)"                     # OSC sequences
    r"|[\x20-\x2f]*[\x40-\x5f]"                  # Other ESC sequences
    r")",
    re.DOTALL,
)


def strip_ansi(text: str) -> str:
    """Remove ANSI escape codes and backspace sequences from text."""
    text = ANSI_RE.sub("", text)
    # Collapse backspace sequences (char + BS) from terminal line editing
    prev = ""
    while prev != text:
        prev = text
        text = re.sub(r"[^\x08]\x08", "", text)
    # Remove any remaining stray backspaces
    text = text.replace("\x08", "")
    return text


# --- Terminal launchers ---

def find_kitty_socket() -> str | None:
    """Find a live kitty instance's remote control socket."""
    import stat
    sockets = glob.glob("/tmp/kitty-*")
    for sock in sockets:
        try:
            st = os.stat(sock)
            if stat.S_ISSOCK(st.st_mode):
                return sock
        except OSError:
            continue
    return None


def kitty_rc_is_alive(socket: str) -> bool:
    """Check if a kitty remote control socket is responsive."""
    try:
        result = subprocess.run(
            ["kitten", "@", "--to", f"unix:{socket}", "ls"],
            capture_output=True, timeout=2,
        )
        return result.returncode == 0
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return False


def launch_kitty(cmd_args: list[str], title: str) -> int:
    """Launch in kitty via remote control, falling back to new process."""
    socket = find_kitty_socket()
    if socket and kitty_rc_is_alive(socket):
        rc_cmd = [
            "kitten", "@", "--to", f"unix:{socket}",
            "launch", "--type=os-window", "--wait-for-child-to-exit",
            "--title", title,
        ] + cmd_args
        result = subprocess.run(rc_cmd)
        return result.returncode

    # Fallback: spawn new kitty process
    kitty_cmd = ["kitty", "--title", title, "--"] + cmd_args
    result = subprocess.run(kitty_cmd)
    return result.returncode


TERMINALS: list[tuple[str, Callable[[], bool], Callable[[list[str], str], int]]] = [
    ("kitty", lambda: shutil.which("kitty") is not None, launch_kitty),
]


def find_terminal() -> tuple[str, Callable[[list[str], str], int]]:
    """Find a supported terminal emulator."""
    env_terminal = os.environ.get("TERMINAL")
    if env_terminal:
        for name, _detect, launch_fn in TERMINALS:
            if name == env_terminal:
                return name, launch_fn
        print(
            f"Error: Terminal '{env_terminal}' (from $TERMINAL) is not supported.\n"
            f"Supported: {', '.join(name for name, _, _ in TERMINALS)}",
            file=sys.stderr,
        )
        sys.exit(1)

    for name, detect, launch_fn in TERMINALS:
        if detect():
            return name, launch_fn

    print(
        "Error: No supported terminal found. Install kitty or set $TERMINAL.",
        file=sys.stderr,
    )
    sys.exit(1)


# --- Inner mode (runs inside the terminal window) ---

def exec_mode(tmpdir: str, command: list[str]) -> int:
    """Execute command inside the terminal, capturing output via script(1).

    This is invoked as: k-term --exec <tmpdir> [command...]
    """
    tmpdir_path = Path(tmpdir)
    output_file = tmpdir_path / "output"
    status_file = tmpdir_path / "status"

    # Resolve command
    if command:
        cmd_display = shlex.join(command)
    else:
        shell = os.environ.get("SHELL", "zsh")
        command = [shell, "-i"]
        cmd_display = shlex.join(command)

    print(f"=== k-term: starting {cmd_display} ===")
    print()

    # Use script(1) to capture terminal output
    # macOS: script -q <file> <command...>
    # Linux: script -q -c <command> <file>
    if sys.platform == "linux":
        script_cmd = ["script", "-q", "-c", shlex.join(command), str(output_file)]
    else:
        script_cmd = ["script", "-q", str(output_file)] + command
    result = subprocess.run(script_cmd)
    exit_code = result.returncode

    print()
    print(f"=== k-term: finished with exit code {exit_code} ===")

    # Write exit code for the outer mode to read
    status_file.write_text(str(exit_code))

    return exit_code


# --- Output formatting ---

def output_plain(
    stdout_content: str,
    stderr_content: str,
    exit_code: int,
) -> None:
    """Print captured output in plain text format."""
    print(f"\n--- k-term session output ---")

    if stdout_content:
        print(stdout_content)

    if stderr_content:
        print(f"\n--- k-term session errors ---")
        print(stderr_content)

    print(f"--- k-term session ended (exit code: {exit_code}) ---")


def output_json(
    stdout_content: str,
    stderr_content: str,
    exit_code: int,
) -> None:
    """Print captured output as structured JSON."""
    result = {
        "exit_code": exit_code,
        "stdout": stdout_content,
        "stderr": stderr_content,
    }
    json.dump(result, sys.stdout)
    print()


# --- Outer mode (main entry point) ---

def main() -> int:
    parser = argparse.ArgumentParser(
        prog="k-term",
        description="Launch an interactive terminal and capture its output.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Output structured JSON",
    )
    parser.add_argument(
        "--title",
        default=None,
        help="Custom terminal window title",
    )
    parser.add_argument(
        "--no-strip-ansi",
        action="store_true",
        help="Keep ANSI escape codes in output (stripped by default)",
    )
    # Hidden flag for self-invocation inside the terminal
    parser.add_argument("--exec", dest="exec_dir", default=None, help=argparse.SUPPRESS)
    parser.add_argument(
        "command",
        nargs=argparse.REMAINDER,
        help="Command to run (default: interactive shell)",
    )
    args = parser.parse_args()

    # REMAINDER may include a leading '--' separator; strip it
    if args.command and args.command[0] == "--":
        args.command = args.command[1:]

    # Inner mode: we're running inside the terminal window
    if args.exec_dir:
        return exec_mode(args.exec_dir, args.command)

    # Outer mode: launch terminal and collect results
    terminal_name, launch_fn = find_terminal()

    # Create temp directory for all working files
    tmpdir = tempfile.mkdtemp(prefix="k-term-")
    tmpdir_path = Path(tmpdir)

    def cleanup():
        shutil.rmtree(tmpdir, ignore_errors=True)

    atexit.register(cleanup)

    original_sigterm = signal.getsignal(signal.SIGTERM)

    def handle_signal(signum, frame):
        cleanup()
        if original_sigterm and callable(original_sigterm):
            original_sigterm(signum, frame)
        sys.exit(128 + signum)

    signal.signal(signal.SIGTERM, handle_signal)

    # Touch output files
    (tmpdir_path / "output").touch()
    status_file = tmpdir_path / "status"

    # Determine window title
    if args.title:
        title = args.title
    elif args.command:
        title = f"k-term: {args.command[0]}"
    else:
        title = "k-term"

    # Build the self-invocation command for inside the terminal
    # Use absolute path so it works even if PATH differs inside kitty
    k_term_path = shutil.which("k-term") or os.path.abspath(sys.argv[0])
    inner_cmd = [k_term_path, "--exec", tmpdir] + args.command

    # Launch terminal (blocks until window closes)
    try:
        launch_fn(inner_cmd, title)
    except FileNotFoundError:
        print(f"Error: Terminal '{terminal_name}' not found in PATH.", file=sys.stderr)
        return 1
    except Exception as e:
        print(f"Error launching terminal: {e}", file=sys.stderr)
        return 1

    # Read results
    output_file = tmpdir_path / "output"
    stdout_content = output_file.read_text() if output_file.exists() else ""
    stderr_content = ""  # script(1) captures everything to one stream

    # Strip ANSI escape codes by default
    if not args.no_strip_ansi:
        stdout_content = strip_ansi(stdout_content)

    # Parse exit code (missing status file means inner mode didn't complete)
    if status_file.exists():
        try:
            exit_code = int(status_file.read_text().strip())
        except (ValueError, OSError):
            exit_code = 1
    else:
        exit_code = 1

    # Output results
    if args.json:
        output_json(stdout_content, stderr_content, exit_code)
    else:
        output_plain(stdout_content, stderr_content, exit_code)

    return exit_code


if __name__ == "__main__":
    sys.exit(main())

{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "kelvin-tools",
  "title": "Kelvin Tools",
  "description": "Personal Raycast utilities",
  "icon": "command-icon.png",
  "author": "kelvin_steiner",
  "authorUrl": "https://github.com/steinerkelvin",
  "license": "MIT",
  "commands": [
    {
      "name": "clean-terminal-paste",
      "title": "Clean Terminal Paste",
      "description": "Strip trailing whitespace from each line of clipboard text (e.g. commands copied from a terminal)",
      "mode": "no-view"
    },
    {
      "name": "simplify-chat-transcript",
      "title": "Simplify Chat Transcript",
      "description": "Clean up and simplify chat transcripts from any platform",
      "mode": "no-view",
      "arguments": [
        {
          "name": "style",
          "type": "dropdown",
          "placeholder": "Format Style",
          "required": false,
          "data": [
            {
              "title": "Grouped",
              "value": "grouped"
            },
            {
              "title": "Flat",
              "value": "flat"
            }
          ]
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.14",
    "eslint": "^8.57.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
